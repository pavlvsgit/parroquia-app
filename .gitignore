# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# extracted EPUB content (copyrighted source text, not for version control)
/.cache/

# raw lecture transcripts (copyrighted source material — the derived work in
# content/catequesis/ is what gets published, not the transcripts themselves)
/transcripts/

# graphify knowledge-graph output (generated/regeneratable, not source)
/graphify-out/

# local Claude Code tool config (personal machine paths, not portable)
/.claude/

# typescript
*.tsbuildinfo
next-env.d.ts
